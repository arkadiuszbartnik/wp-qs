# Docker - project configurations are tracked
# Dockerfile and docker-compose.yml are part of the project
docker-compose.override.yml
.docker/

# WordPress Core - available locally for IDE, but not tracked in Git
# Ignore main WordPress core files
wordpress-core/
wp-admin
wp-includes
wp-*.php
index.php
readme.html
license.txt
xmlrpc.php

# Keep only our configurations and structure
!wp-config.php
!wp-content/index.php

# All plugins and themes should be submodules (separate repositories)
# Newly created plugins will be automatically ignored
wp-content/plugins/*
wp-content/languages/*
wp-content/themes/*
wp-content/**/*

# Keep only README in plugins and themes directories
!wp-content/plugins/README.md
!wp-content/themes/README.md
!wp-content/plugins/.gitkeep  
!wp-content/themes/.gitkeep



# Uploads - only sample files
wp-content/uploads/*
!wp-content/uploads/.gitkeep

# Database backups (keep directory but exclude SQL files)
data/backups/*.sql

# Database data (local MySQL files)
data/mysql_data/

# Logs
data/logs/apache/*.log
data/logs/mysql/*.log
*.log
error_log

# Environment files
.env
.env.local
.env.production

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Node modules (if using any build tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Composer
vendor/
composer.lock
# composer.json is tracked as it contains project dependencies definition

# MySQL data
data/mysql_data/

# Temporary files
*.tmp
*.temp
*.bak
*.backup
temp_theme_download/
wordpress-core-tmp/

# Distribution packages
dist/

# Test logs
logs/
*.log
